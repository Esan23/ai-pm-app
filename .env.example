# Server-side key for the Claude-backed capture function (netlify/functions/capture.ts).
# Set this in the Netlify dashboard (Site configuration → Environment variables).
# When unset, the app runs in demo mode: capture falls back to a local heuristic.
ANTHROPIC_API_KEY=

# Optional (future): Supabase auth + persistence. When unset, the app runs guest-only.
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
